<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sumeet Kumar — Builder, Thinker, Creator</title>
  <meta name="description" content="Sumeet Kumar is a Software Engineer working on multiple avenueues." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <!-- NAV -->
  <header class="nav" id="nav">
    <div class="nav__inner">
      <a href="#" class="nav__logo">YN</a>
      <nav class="nav__links">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#writing">Writing</a>
        <a href="#contact">Contact</a>
      </nav>
      <a href="resume.pdf" class="btn btn--ghost" target="_blank">Resume ↗</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__eyebrow">Hi, I'm</p>
      <h1 class="hero__name">
        <span class="hero__name-text">Sumeet Kumar</span>
      </h1>
      <p class="hero__tagline">
        I build things at the intersection of <em>technology</em> and <em>human experience</em>.
        Currently focused on [your current focus].
      </p>
      <div class="hero__actions">
        <a href="#projects" class="btn btn--primary">See my work</a>
        <a href="#writing" class="btn btn--ghost">Read my writing</a>
      </div>
      <div class="hero__chips">
        <span class="chip">Software Engineer</span>
        <span class="chip">Open Source</span>
        <span class="chip">Based in Gothenburg</span>
      </div>
    </div>
    <div class="hero__scroll-hint" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="section__inner section__inner--split">
      <div class="section__label">About</div>
      <div class="section__body">
        <h2 class="section__heading">A little about me</h2>
        <p>
          I'm a [your role] with a passion for [your passion]. I've spent the last [X] years
          working on [domain], and I care deeply about building things that are both technically
          excellent and genuinely useful to people.
        </p>
        <p>
          Before [current thing], I studied [field] at [university]. Outside of work I'm usually
          [hobby 1], [hobby 2], or reading about [interest].
        </p>
        <div class="stat-row">
          <div class="stat">
            <span class="stat__number">5+</span>
            <span class="stat__label">Years of experience</span>
          </div>
          <div class="stat">
            <span class="stat__number">12</span>
            <span class="stat__label">Projects shipped</span>
          </div>
          <div class="stat">
            <span class="stat__number">3</span>
            <span class="stat__label">Open-source tools</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section section--alt" id="projects">
    <div class="section__inner">
      <div class="section__label">Projects</div>
      <h2 class="section__heading">Things I've built</h2>
      <div class="card-grid">

        <article class="card">
          <div class="card__header">
            <span class="card__tag">Web App</span>
            <a href="#" class="card__link" aria-label="View Project One">↗</a>
          </div>
          <h3 class="card__title">Project One</h3>
          <p class="card__desc">
            A short description of what this does and why it matters. What problem does it solve?
            Who uses it?
          </p>
          <div class="card__tech">
            <span>React</span><span>TypeScript</span><span>Postgres</span>
          </div>
        </article>

        <article class="card">
          <div class="card__header">
            <span class="card__tag">Open Source</span>
            <a href="#" class="card__link" aria-label="View Project Two">↗</a>
          </div>
          <h3 class="card__title">Project Two</h3>
          <p class="card__desc">
            What makes this project interesting or different. Keep it concrete — a real use
            case is more compelling than vague praise.
          </p>
          <div class="card__tech">
            <span>Python</span><span>FastAPI</span><span>Docker</span>
          </div>
        </article>

        <article class="card">
          <div class="card__header">
            <span class="card__tag">CLI Tool</span>
            <a href="#" class="card__link" aria-label="View Project Three">↗</a>
          </div>
          <h3 class="card__title">Project Three</h3>
          <p class="card__desc">
            Describe the motivation behind building this. What were you frustrated by that
            made you decide to build it yourself?
          </p>
          <div class="card__tech">
            <span>Go</span><span>Shell</span>
          </div>
        </article>

        <article class="card">
          <div class="card__header">
            <span class="card__tag">Research</span>
            <a href="#" class="card__link" aria-label="View Project Four">↗</a>
          </div>
          <h3 class="card__title">Project Four</h3>
          <p class="card__desc">
            A fourth project — or remove this card if you only have three things worth
            showing. Quality beats quantity every time.
          </p>
          <div class="card__tech">
            <span>C++</span><span>CMake</span>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- WRITING -->
  <section class="section" id="writing">
    <div class="section__inner">
      <div class="section__label">Writing</div>
      <h2 class="section__heading">Ideas worth sharing</h2>
      <div class="post-list">

        <a href="#" class="post">
          <div class="post__meta">
            <span class="post__date">Jun 2025</span>
            <span class="post__tag">Engineering</span>
          </div>
          <h3 class="post__title">Your most interesting essay title goes here</h3>
          <p class="post__excerpt">
            A single sentence that makes the reader want to click. Lead with the insight,
            not the topic.
          </p>
        </a>

        <a href="#" class="post">
          <div class="post__meta">
            <span class="post__date">Mar 2025</span>
            <span class="post__tag">Thinking</span>
          </div>
          <h3 class="post__title">A second piece you're proud of</h3>
          <p class="post__excerpt">
            What's the one idea in this post that someone would text to a friend? Lead
            with that.
          </p>
        </a>

        <a href="#" class="post">
          <div class="post__meta">
            <span class="post__date">Jan 2025</span>
            <span class="post__tag">Tools</span>
          </div>
          <h3 class="post__title">Something practical and specific</h3>
          <p class="post__excerpt">
            Concrete beats abstract. "How I reduced compile time by 60%" outperforms
            "Thoughts on build systems."
          </p>
        </a>

      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section section--alt" id="contact">
    <div class="section__inner section__inner--center">
      <div class="section__label">Contact</div>
      <h2 class="section__heading">Let's talk</h2>
      <p class="section__subtext">
        I'm always interested in thoughtful projects, good conversations, and
        the occasional coffee. The best way to reach me is email.
      </p>
      <a href="mailto:sumeet.29kumar@gmail.com" class="btn btn--primary btn--lg">
        Send an email ↗
      </a>
      <div class="social-row">
        <a href="https://github.com/ksumeet29" target="_blank" rel="noopener" class="social-link">GitHub</a>
        <a href="https://linkedin.com/in/ksumeet29" target="_blank" rel="noopener" class="social-link">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__inner">
      <span class="footer__name">Sumeet Kumar</span>
      <span class="footer__copy">© 2025 — Built with care</span>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
