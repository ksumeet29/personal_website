<!DOCTYPE html>
<html lang="en">
<head>
  <base href="/personal_website/" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sumeet Kumar — Builder, Thinker, Creator</title>
  <meta name="description" content="Sumeet Kumar is a Software Engineer working on multiple avenueues." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <!-- NAV -->
  <header class="nav" id="nav">
    <div class="nav__inner">
      <a href="index.html" class="nav__logo">SK</a>
      <nav class="nav__links">
        <a href="about.html">About</a>
        <a href="projects.html">Projects</a>
        <a href="writing.html">Writing</a>
        <a href="#contact">Contact</a>
      </nav>
      <a href="resume.pdf" class="btn btn--ghost" target="_blank">Resume ↗</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__inner hero__inner--split">

      <!-- Left: text -->
      <div class="hero__text">
        <p class="hero__eyebrow">Hi, I'm</p>
        <h1 class="hero__name">
          <span class="hero__name-text">Sumeet Kumar</span>
        </h1>
        <p class="hero__tagline">
          I am an <em>Automotive Software Engineer</em> working on next generation vehicles.
          Currently focused on Embedded Software Development and Vehicle Testing.
        </p>
        <div class="hero__actions">
          <a href="#projects" class="btn btn--primary">See my work</a>
          <a href="#writing" class="btn btn--ghost">Read my writing</a>
        </div>
        <div class="hero__chips">
          <span class="chip">Automotive Software Engineer</span>
          <span class="chip">Based in Gothenburg, Sweden</span>
        </div>
      </div>

      <!-- Right: my_photo -->
      <div class="hero__photo-wrap">
        <div class="hero__photo-ring">
          <img
            src="my_photo.jpg"
            alt="Sumeet Kumar"
            class="hero__photo"
            style="width:100%;height:100%;object-fit:cover;object-position:center top;"
            onerror="this.parentElement.classList.add('hero__photo-ring--placeholder')"
          />
        </div>
      </div>

    </div>

    <!-- Scroll arrow -->
    <div class="hero__scroll-hint" aria-hidden="true">
      <span class="scroll-arrow">↓</span>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section section--alt" id="contact">
    <div class="section__inner section__inner--center">
      <div class="section__label">Contact</div>
      <h2 class="section__heading">Let's talk</h2>
      <p class="section__subtext">
        I'm always interested in thoughtful projects, good conversations, and
        the occasional coffee. The best way to reach me is email.
      </p>
      <a href="mailto:sumeet.29kumar@gmail.com" class="btn btn--primary btn--lg">
        Send an email ↗
      </a>
      <div class="social-row">
        <a href="https://github.com/ksumeet29" target="_blank" rel="noopener" class="social-link">GitHub</a>
        <a href="https://linkedin.com/in/ksumeet29" target="_blank" rel="noopener" class="social-link">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__inner">
      <span class="footer__name">Sumeet Kumar</span>
      <span class="footer__copy">© 2026 — Built with care</span>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
