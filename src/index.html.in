<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@PROJECT_NAME@</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Sumeet Kumar</h1>
        <p class="tagline">Automotive Software Engineer</p>
        <p class="meta">Built with CMake &bull; v@PROJECT_VERSION@ &bull; @BUILD_DATE@</p>
    </header>

    <main>
        <section>
            <h2>About</h2>
            <p>This is my personal website, generated by CMake and hosted on GitHub Pages.</p>
        </section>

        <section>
            <h2>Contact</h2>
            <ul class="contact-list">
                <li>
                    <span class="label">Email</span>
                    <a href="mailto:sumeet.29kumar@gmail.com">sumeet.29kumar@gmail.com</a>
                </li>
                <li>
                    <span class="label">Phone</span>
                    <a href="tel:+46727852565">+46727852565</a>
                </li>
                <li>
                    <span class="label">LinkedIn</span>
                    <a href="https://www.linkedin.com/in/ksumeet29/" target="_blank" rel="noopener">
                        linkedin.com/in/ksumeet29
                    </a>
                </li>
                <li>
                    <span class="label">Resume</span>
                    <a href="resume.pdf" target="_blank" rel="noopener">Download (PDF)</a>
